size(600, 300)
background('#004477')
noStroke()
x = 300
size = 550
minus = 50

fill("#FF3651")
circle(x,x, size)

fill("#FFA536")
circle(x,x, size - minus)

fill("#F1FF36")
circle(x,x, size - minus * 2)

fill("#36FF55")
circle(x,x, size - minus * 3)

fill("#36FFFD")
circle(x,x, size - minus * 4)

fill("#AA36FF")
circle(x,x, size - minus * 5)

fill("#004477")
circle(x,x, size - minus * 6)
